# ═══════════════════════════════════════════════════════
# CONCERTOS — Environment Configuration Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════

PORT=3000

# ── AI PROVIDERS ───────────────────────────────────────
# Groq: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# OpenRouter: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── BAILEYS WEBSOCKET MODE ────────────────────────────────
# USE_BAILEYS=true (default) → Baileys WebSocket, QR code connection
# USE_BAILEYS=false → Legacy whatsapp-web.js (Puppeteer/Chromium, DEPRECATED)
# Baileys includes: Anti-Ban Protocol, Presence Emulation, Rate Limiting,
# AI Message Variability, Auto-Prune (30min idle), Auto-Wake, 7-day Session Cleanup.
USE_BAILEYS=true

# ── INFRASTRUCTURE ──────────────────────────────────────
# Redis:
#   LOCAL DEV:  redis://localhost:6379
#   PRODUCTION: redis://your-vps-ip:6379
REDIS_URL=redis://localhost:6379

# MongoDB:
#   LOCAL DEV:  mongodb://127.0.0.1:27017/brandpro
#   PRODUCTION: mongodb://your-vps-ip:27017/brandpro
MONGODB_URI=mongodb://127.0.0.1:27017/brandpro

# ── GOOGLE OAUTH ────────────────────────────────────────
# Create at: https://console.cloud.google.com > APIs & Services > Credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=https://dash.concertos.brandproinc.in/settings

# ── JWT AUTHENTICATION ──────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# This secret MUST match the JWT_SECRET in concertos-dashboard/.env.local
JWT_SECRET=your_jwt_secret_here

# Set to 'true' ONLY for local development. NEVER in production.
ALLOW_UNAUTHENTICATED=false

# ── RATE LIMITING ───────────────────────────────────────
# Max outbound WhatsApp messages per client per 60-second window
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_MESSAGES=30
